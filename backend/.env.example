# PostgreSQL (обязательно)
DATABASE_URL=postgresql://user:password@localhost:5432/vpa

# Порт API (по умолчанию 3000)
PORT=3000

# Корень статики (HTML/CSS/JS сайта). По умолчанию родительская папка backend/
STATIC_DIR=../

# Twenty CRM (опционально). Если заданы — заявки создают клиента (Person) и при TWENTY_PIPELINE_STAGE_ID — сделку (Opportunity) в стадии «Новый заказ»
# URL вашего Twenty без слэша, например https://crm.example.com
# TWENTY_API_URL=
# TWENTY_API_KEY=
# ID стадии pipeline для «Новый заказ» (взять в Twenty: настройки pipeline → скопировать id стадии)
# TWENTY_PIPELINE_STAGE_ID=
